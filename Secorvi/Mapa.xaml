<Window x:Class="Secorvi.Mapa"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Radar de Ubicaciones - SECORVI"
        Height="800" Width="1100"
        WindowStartupLocation="CenterOwner"
        Background="#0B0D12"
        Language="es-MX"
        WindowStyle="None" AllowsTransparency="True">

    <Window.Resources>
        <Style x:Key="ModernInput" TargetType="TextBox">
            <Setter Property="Background" Value="#12161D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2D323E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="CaretBrush" Value="#FFB300"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="IndustrialButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1A1F26"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#2D323E"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border BorderBrush="#2D323E" BorderThickness="1">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#161920" BorderBrush="#2D323E" BorderThickness="0,0,1,0">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,15">
                        <TextBlock Text="SECORVI RADAR" Foreground="#FFB300" FontSize="20" FontWeight="Black"/>
                        <Border Background="#0F111A" CornerRadius="2" Padding="8,4" Margin="0,5,0,0">
                            <TextBlock x:Name="lblEmpleadoActivo" Text="AGENTE SELECCIONADO: ---" Foreground="#2ECC71" FontSize="11" FontWeight="Bold"/>
                        </Border>
                    </StackPanel>

                    <Grid Grid.Row="1" Margin="0,0,0,10">
                        <TextBox x:Name="txtBusqueda" Style="{StaticResource ModernInput}" Padding="28,5,5,5"/>
                        <TextBlock Text="🔍" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="8,0,0,0" Foreground="#4B5563" IsHitTestVisible="False"/>
                    </Grid>

                    <Grid Grid.Row="2" Margin="0,0,0,10">
                        <ListBox x:Name="lstUbicaciones" Background="Transparent" BorderThickness="0" 
                                 SelectionMode="Extended" SelectionChanged="lstUbicaciones_SelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#1A1F26" BorderBrush="#2D323E" BorderThickness="1" Padding="10" Margin="0,0,0,5" CornerRadius="2">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="📍" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding nombre_lugar}" Foreground="White" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>

                    <Border Grid.Row="3" Background="#11141B" BorderBrush="#2D323E" BorderThickness="1" Padding="12" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="PREAJUSTES DE TURNO" Foreground="#6B7280" FontSize="8" FontWeight="Bold" Margin="0,0,0,5"/>
                            <UniformGrid Columns="3" Margin="0,0,0,12">
                                <Button Content="8 HORAS" Click="BtnTurno8_Click" Style="{StaticResource IndustrialButtonStyle}" Height="30" Margin="0,0,4,0"/>
                                <Button Content="12 HORAS" Click="BtnTurno12_Click" Style="{StaticResource IndustrialButtonStyle}" Height="30" Margin="0,0,4,0"/>
                                <Button Content="24 HORAS" Click="BtnTurno24_Click" Style="{StaticResource IndustrialButtonStyle}" Height="30"/>
                            </UniformGrid>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                    <TextBlock Text="HORA ENTRADA" Foreground="#6B7280" FontSize="8" FontWeight="Bold"/>
                                    <DockPanel>
                                        <ComboBox x:Name="cbAmPmI" DockPanel.Dock="Right" Width="55" Background="#12161D" Foreground="Black">
                                            <ComboBoxItem Content="AM" IsSelected="True"/>
                                            <ComboBoxItem Content="PM"/>
                                        </ComboBox>
                                        <ComboBox x:Name="cbHoraInicio" IsEditable="True" Background="#12161D" Foreground="Black"/>
                                    </DockPanel>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="4,0,0,0">
                                    <TextBlock Text="HORA SALIDA" Foreground="#6B7280" FontSize="8" FontWeight="Bold"/>
                                    <DockPanel>
                                        <ComboBox x:Name="cbAmPmF" DockPanel.Dock="Right" Width="55" Background="#12161D" Foreground="Black">
                                            <ComboBoxItem Content="AM"/>
                                            <ComboBoxItem Content="PM" IsSelected="True"/>
                                        </ComboBox>
                                        <ComboBox x:Name="cbHoraFin" IsEditable="True" Background="#12161D" Foreground="Black"/>
                                    </DockPanel>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="FECHA DE SERVICIO" Foreground="#6B7280" FontSize="8" FontWeight="Bold" Margin="0,0,0,2"/>
                            <DatePicker x:Name="dpFecha" Margin="0,0,0,10"/>
                            <TextBlock Text="PUNTO / CLIENTE" Foreground="#6B7280" FontSize="8" FontWeight="Bold" Margin="0,0,0,2"/>
                            <TextBox x:Name="txtNombrePunto" Style="{StaticResource ModernInput}" Margin="0,0,0,10"/>
                            <Border Background="#0B0D12" Padding="5" BorderBrush="#2D323E" BorderThickness="1">
                                <TextBlock x:Name="txtCoords" Text="PUNTO NO MARCADO" Foreground="#2ECC71" FontSize="9" HorizontalAlignment="Center" FontWeight="Bold"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <UniformGrid Grid.Row="4" Columns="2">
                        <Button Content="CANCELAR" Click="BtnCancelar_Click" Height="45" Background="#2D323E" Foreground="White" Margin="0,0,5,0" Cursor="Hand"/>
                        <Button Content="GUARDAR" Click="BtnGuardar_Click" Height="45" Background="#FFB300" Foreground="#0F111A" FontWeight="Bold" Cursor="Hand"/>
                    </UniformGrid>
                </Grid>
            </Border>

            <wv2:WebView2 x:Name="mapaWebView" Grid.Column="1" DefaultBackgroundColor="#0F111A"/>
        </Grid>
    </Border>
</Window>