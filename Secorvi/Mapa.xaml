<Window x:Class="Secorvi.Mapa"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Radar de Ubicaciones - SECORVI"
        Height="800" Width="1100"
        WindowStartupLocation="CenterOwner"
        Background="#0B0D12"
        Language="es-MX"
        WindowStyle="None" AllowsTransparency="True">

    <Window.Resources>
        <Style x:Key="ModernInput" TargetType="TextBox">
            <Setter Property="Background" Value="#12161D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2D323E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="CaretBrush" Value="#FFB300"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Border BorderBrush="#2D323E" BorderThickness="1">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#161920" BorderBrush="#2D323E" BorderThickness="0,0,1,0">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,15">
                        <TextBlock Text="SECORVI RADAR" Foreground="#FFB300" FontSize="20" FontWeight="Black"/>
                        <Border Background="#0F111A" CornerRadius="2" Padding="8,4" Margin="0,5,0,0">
                            <TextBlock x:Name="lblEmpleadoActivo" Text="AGENTE SELECCIONADO: ---" Foreground="#2ECC71" FontSize="11" FontWeight="Bold"/>
                        </Border>
                    </StackPanel>

                    <Grid Grid.Row="1" Margin="0,0,0,10">
                        <TextBox x:Name="txtBusqueda" Style="{StaticResource ModernInput}" Padding="28,5,5,5"/>
                        <TextBlock Text="🔍" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="8,0,0,0" Foreground="#4B5563" IsHitTestVisible="False"/>
                    </Grid>

                    <Grid Grid.Row="2" Margin="0,0,0,10">
                        <ListBox x:Name="lstUbicaciones" Background="Transparent" BorderThickness="0" 
                                 SelectionMode="Extended" SelectionChanged="lstUbicaciones_SelectionChanged">
                            <ListBox.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="🗑️ ELIMINAR SELECCIÓN" Click="BtnEliminarVarios_Click"/>
                                </ContextMenu>
                            </ListBox.ContextMenu>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#1A1F26" BorderBrush="#2D323E" BorderThickness="1" Padding="10" Margin="0,0,0,5" CornerRadius="2">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="📍" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding nombre_lugar}" Foreground="White" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="BorderBrush" Value="#FFB300"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                    </Grid>

                    <Border Grid.Row="3" Background="#11141B" BorderBrush="#2D323E" BorderThickness="1" Padding="12" Margin="0,0,0,15">
                        <StackPanel>
                            <UniformGrid Columns="2" Margin="0,0,0,10">
                                <StackPanel Margin="0,0,4,0">
                                    <TextBlock Text="HORA ENTRADA" Foreground="#6B7280" FontSize="8" FontWeight="Bold"/>
                                    <TextBox x:Name="txtHoraInicio" Text="07:00 AM" Style="{StaticResource ModernInput}"/>
                                </StackPanel>
                                <StackPanel Margin="4,0,0,0">
                                    <TextBlock Text="HORA SALIDA" Foreground="#6B7280" FontSize="8" FontWeight="Bold"/>
                                    <TextBox x:Name="txtHoraFin" Text="02:00 PM" Style="{StaticResource ModernInput}"/>
                                </StackPanel>
                            </UniformGrid>
                            <TextBlock Text="FECHA DE SERVICIO" Foreground="#6B7280" FontSize="8" FontWeight="Bold" Margin="0,0,0,2"/>
                            <DatePicker x:Name="dpFecha" Margin="0,0,0,10"/>
                            <TextBlock Text="NOMBRE DEL PUNTO / CLIENTE" Foreground="#6B7280" FontSize="8" FontWeight="Bold" Margin="0,0,0,2"/>
                            <TextBox x:Name="txtNombrePunto" Style="{StaticResource ModernInput}" Margin="0,0,0,10"/>
                            <Border Background="#0B0D12" Padding="5" BorderBrush="#2D323E" BorderThickness="1">
                                <TextBlock x:Name="txtCoords" Text="PUNTO NO MARCADO" Foreground="#2ECC71" FontSize="9" HorizontalAlignment="Center" FontWeight="Bold"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <UniformGrid Grid.Row="5" Columns="2">
                        <Button Content="CANCELAR" Click="BtnCancelar_Click" Height="45" Background="#2D323E" Foreground="White" Margin="0,0,5,0" Cursor="Hand"/>
                        <Button Content="GUARDAR" Click="BtnGuardar_Click" Height="45" Background="#FFB300" Foreground="#0F111A" FontWeight="Bold" Cursor="Hand"/>
                    </UniformGrid>
                </Grid>
            </Border>

            <wv2:WebView2 x:Name="mapaWebView" Grid.Column="1" DefaultBackgroundColor="#0F111A"/>
        </Grid>
    </Border>
</Window>