<Window x:Class="Secorvi.SeleccionarFechaLibre"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Asignar Descanso" Height="380" Width="320"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#1A1A1A" Foreground="White">

    <Border Padding="20" BorderBrush="#333333" BorderThickness="1">
        <Grid>
            <StackPanel>
                <TextBlock Text="SELECCIONE FECHA DE DESCANSO" 
                           Foreground="#FFC107" 
                           FontWeight="Bold" 
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,15"/>

                <Border BorderBrush="#FFC107" BorderThickness="1" HorizontalAlignment="Center">
                    <Calendar Name="calFecha" Language="es-MX" />
                </Border>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                    <Button Content="CONFIRMAR" 
                            Click="BtnConfirmar_Click" 
                            Width="110" Height="35" 
                            Background="#FFC107" 
                            Foreground="Black" 
                            FontWeight="Bold" 
                            Margin="0,0,10,0"
                            Cursor="Hand"/>

                    <Button Content="CANCELAR" 
                            IsCancel="True" 
                            Width="110" Height="35" 
                            Background="#333333" 
                            Foreground="White"
                            Cursor="Hand"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</Window>