<Page x:Class="Secorvi.PanelDeControl"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="SECORVI - Panel de Control" 
      Height="800" Width="1200"
      Background="#0B0D12" Language="es-MX">

    <Page.Resources>
        <Style x:Key="IndustrialButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#161A21"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#2D323E"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1E2530"/>
                                <Setter Property="BorderBrush" Value="#FFB300"/>
                                <Setter Property="Cursor" Value="Hand"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#1E252F"/>
            <Setter Property="Foreground" Value="#FFB300"/>
            <Setter Property="BorderBrush" Value="#2D323E"/>
            <Setter Property="BorderThickness" Value="0,0,1,2"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2D323E"/>
                    <Setter Property="Foreground" Value="#FFB300"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#2D323E"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#161920"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#161920" CornerRadius="8,8,0,0" Padding="20" BorderBrush="#2D323E" BorderThickness="1">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="SECORVI" Foreground="#FFB300" FontSize="26" FontWeight="Black"/>
                        <TextBlock Text="OPERATIONS CONTROL CENTER" Foreground="#4B5563" FontSize="9" FontWeight="Bold" Margin="2,-4,0,0"/>
                    </StackPanel>
                    <Rectangle Width="1" Fill="#2D323E" Margin="25,5" Height="40"/>
                    <Button Content="+ REGISTRAR AGENTE" Click="BtnNuevo_Click" Style="{StaticResource IndustrialButtonStyle}" Background="#FFB300" Foreground="#0F111A" FontWeight="Black" Width="180" Height="40"/>
                    <Button x:Name="btnRoles" Content="🛡️ PERMISOS" Click="BtnRoles_Click" Style="{StaticResource IndustrialButtonStyle}" Width="130" Height="40" Margin="10,0"/>
                </StackPanel>
                <Button Content="❌ DAR DE BAJA" Click="BtnEliminar_Click" DockPanel.Dock="Right" Style="{StaticResource IndustrialButtonStyle}" Background="#3D1B1E" Foreground="#FF5252" BorderBrush="#FF5252" Width="150" Height="40"/>
            </DockPanel>
        </Border>

        <Border Grid.Row="1" Background="#12151B" Padding="20,10" BorderBrush="#2D323E" BorderThickness="1,0,1,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="FILTRAR AGENTES:" Foreground="#6B7280" FontWeight="Bold" VerticalAlignment="Center" FontSize="10" Margin="0,0,15,0"/>
                <TextBox x:Name="txtBusqueda" Grid.Column="1" Height="32" Background="#161920" Foreground="White" BorderBrush="#2D323E" BorderThickness="1" VerticalContentAlignment="Center" Padding="10,0" TextChanged="TxtBusqueda_TextChanged"/>
                <TextBlock Grid.Column="2" Text="Registros: 0" x:Name="lblTotal" Foreground="#4B5563" VerticalAlignment="Center" Margin="15,0,0,0" FontSize="10"/>
            </Grid>
        </Border>

        <Border Grid.Row="2" Background="#0F111A" BorderBrush="#2D323E" BorderThickness="1,0,1,1">
            <DataGrid x:Name="dgEmpleados" AutoGenerateColumns="False" CanUserAddRows="False" 
                      Background="Transparent" RowHeight="65" HeadersVisibility="Column" 
                      IsReadOnly="True" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#1A1F26"
                      MouseDoubleClick="DgEmpleados_MouseDoubleClick" BorderThickness="0">
                <DataGrid.Columns>

                    <DataGridTextColumn Header="MATRÍCULA" Binding="{Binding Matricula}" Width="110">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#FFB300"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="TextAlignment" Value="Center"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="FontFamily" Value="Consolas"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTemplateColumn Header="RANGO" Width="110">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border x:Name="brdRango" Background="#0F111A" BorderThickness="1" CornerRadius="2" Padding="6,2" HorizontalAlignment="Center" VerticalAlignment="Center" BorderBrush="#4B5563">
                                    <TextBlock x:Name="txtRango" Text="AGENTE" Foreground="#4B5563" FontSize="9" FontWeight="Black" FontFamily="Consolas"/>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding EsAdmin}" Value="True">
                                        <Setter TargetName="txtRango" Property="Text" Value="ADMIN"/>
                                        <Setter TargetName="txtRango" Property="Foreground" Value="#FFB300"/>
                                        <Setter TargetName="brdRango" Property="BorderBrush" Value="#FFB300"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="AGENTE" Binding="{Binding NombreCompleto}" Width="200">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Margin" Value="10,0"/>
                                <Setter Property="Foreground" Value="#E0E0E0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTemplateColumn Header="ASISTENCIA HOY" Width="135">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Border x:Name="brdAsistencia" Width="22" Height="22" CornerRadius="11" BorderThickness="2">
                                        <TextBlock x:Name="txtIcono" Text="×" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Black" FontSize="12" Margin="0,0,0,1"/>
                                    </Border>
                                    <TextBlock x:Name="txtEstadoAsistencia" Text="PENDIENTE" Margin="8,0,0,0" VerticalAlignment="Center" FontSize="10" FontWeight="Black" FontFamily="Consolas"/>
                                </StackPanel>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding CumplioAsistenciaHoy}" Value="True">
                                        <Setter TargetName="brdAsistencia" Property="Background" Value="#1A2E21"/>
                                        <Setter TargetName="brdAsistencia" Property="BorderBrush" Value="#2ECC71"/>
                                        <Setter TargetName="txtIcono" Property="Text" Value="✓"/>
                                        <Setter TargetName="txtIcono" Property="Foreground" Value="#2ECC71"/>
                                        <Setter TargetName="txtEstadoAsistencia" Property="Text" Value="CUMPLIÓ"/>
                                        <Setter TargetName="txtEstadoAsistencia" Property="Foreground" Value="#2ECC71"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding CumplioAsistenciaHoy}" Value="False">
                                        <Setter TargetName="brdAsistencia" Property="Background" Value="#2D1B1E"/>
                                        <Setter TargetName="brdAsistencia" Property="BorderBrush" Value="#E74C3C"/>
                                        <Setter TargetName="txtIcono" Property="Foreground" Value="#E74C3C"/>
                                        <Setter TargetName="txtEstadoAsistencia" Property="Text" Value="FALTA"/>
                                        <Setter TargetName="txtEstadoAsistencia" Property="Foreground" Value="#E74C3C"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="ESTADO DE ASISTENCIA (WHATSAPP)" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="#161920" CornerRadius="4" Padding="12,5" Margin="10,5" BorderThickness="1" BorderBrush="#2D323E">
                                    <DockPanel>
                                        <Ellipse Width="8" Height="8" Fill="{Binding ColorStatus}" DockPanel.Dock="Right" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding UltimoReporteHora}" Foreground="{Binding ColorStatus}" FontSize="11" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding UltimoReporteUbicacion}" Foreground="#6B7280" FontSize="10"/>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="ACCIONES" Width="140">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="📅 CALENDARIO" 
                                        Click="BtnCalendario_Click"
                                        Background="Transparent" BorderBrush="#FFB300" Foreground="#FFB300" 
                                        FontSize="10" FontWeight="Bold" Padding="8,4" Cursor="Hand"
                                        VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#2D323E"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Row="3" Background="#161920" CornerRadius="0,0,8,8" Padding="20,12" BorderBrush="#2D323E" BorderThickness="1,0,1,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="ESTADOS DE ASISTENCIA:" Foreground="#4B5563" FontSize="9" FontWeight="Black" Margin="0,0,15,0" VerticalAlignment="Center"/>

                    <Ellipse Width="8" Height="8" Fill="#2ECC71" Margin="0,0,5,0"/>
                    <TextBlock Text="EN PUNTO" Foreground="#E0E0E0" FontSize="9" Margin="0,0,15,0" VerticalAlignment="Center"/>

                    <Ellipse Width="8" Height="8" Fill="#F1C40F" Margin="0,0,5,0"/>
                    <TextBlock Text="REPORTE FUERA" Foreground="#E0E0E0" FontSize="9" Margin="0,0,15,0" VerticalAlignment="Center"/>

                    <Ellipse Width="8" Height="8" Fill="#E74C3C" Margin="0,0,5,0"/>
                    <TextBlock Text="SIN REPORTE" Foreground="#E0E0E0" FontSize="9" Margin="0,0,15,0" VerticalAlignment="Center"/>

                    <Rectangle Width="1" Fill="#2D323E" Margin="10,2" Height="15"/>

                    <TextBlock Text="🖱️ DOBLE CLIC: Abrir Calendario" Foreground="#6B7280" FontSize="9" Margin="15,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="ENGINE:" Foreground="#4B5563" FontSize="9" FontWeight="Black" VerticalAlignment="Center"/>
                    <TextBlock Text=" n8n ACTIVE" Foreground="#2ECC71" FontSize="10" FontWeight="Bold" VerticalAlignment="Center" Margin="5,0,0,0"/>
                    <Rectangle Width="1" Fill="#2D323E" Margin="15,2" Height="15"/>
                    <TextBlock Text="SECORVI v2.0" Foreground="#FFB300" FontSize="10" FontWeight="Black" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>