<Page x:Class="Secorvi.PanelDeControl"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="SECORVI - Panel de Control" 
      Height="800" Width="1200"
      Background="#0B0D12">

    <Page.Resources>
        <Style x:Key="IndustrialButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#161A21"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#2D323E"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1E2530"/>
                                <Setter Property="BorderBrush" Value="#2ECC71"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="GhostWhite"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#2D323E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2D323E"/>
                    <Setter Property="Foreground" Value="#FFB300"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="#1A1F26"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#212730"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#161920" BorderBrush="#2D323E" BorderThickness="1" Padding="15" Margin="0,0,0,10" CornerRadius="4">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="SECORVI" Foreground="#FFB300" FontSize="28" FontWeight="Black"/>
                        <TextBlock Text="OPERATIONS CONTROL CENTER" Foreground="#4B5563" FontSize="10" FontWeight="Bold" Margin="2,-4,0,0" />
                    </StackPanel>
                    <Separator Width="30" Visibility="Hidden"/>
                    <StackPanel VerticalAlignment="Center" Margin="10,0">
                        <TextBlock Text="TARIFA POR HORA" Foreground="#6B7280" FontSize="9" FontWeight="Bold" Margin="0,0,0,2"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBox x:Name="txtTarifaGlobal" Text="35.5" Width="65" Height="28" Background="#21262E" Foreground="#FFB300" FontWeight="Bold" FontSize="14" BorderBrush="#FFB300" BorderThickness="1" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
                            <Button Content="💾" Click="BtnActualizarTarifa_Click" Style="{StaticResource IndustrialButtonStyle}" Width="32" Height="28" Margin="5,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                    <Separator Width="20" Visibility="Hidden"/>
                    <Button Content="🌐 RADAR" Click="BtnMapa_Click" Style="{StaticResource IndustrialButtonStyle}" Foreground="#47FFFF" Width="90" Height="40" Margin="5,0"/>
                    <Button Content="📅 DÍA LIBRE" Click="BtnDiaLibre_Click" Style="{StaticResource IndustrialButtonStyle}" Width="100" Height="40"/>
                    <Button Content="+ AGREGAR" Click="BtnNuevo_Click" Style="{StaticResource IndustrialButtonStyle}" Width="110" Height="40" Margin="5,0" Background="#FFB300" Foreground="#0F111A" FontWeight="Black"/>
                </StackPanel>
                <Button Content="❌ ELIMINAR" Click="BtnEliminar_Click" DockPanel.Dock="Right" Style="{StaticResource IndustrialButtonStyle}" Background="#3D1B1E" Foreground="#FF5252" BorderBrush="#FF5252" Width="100" Height="40" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <Border Grid.Row="1" Background="#161920" BorderBrush="#2D323E" BorderThickness="1,0,1,1" Padding="15,8" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="BUSCAR AGENTE:" Foreground="#6B7280" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,15,0" FontSize="11"/>
                <TextBox x:Name="txtBusqueda" Width="400" Height="24" Background="#21262E" Foreground="#FFFFFF" BorderBrush="#374151" BorderThickness="1" VerticalContentAlignment="Center" Padding="10,0" TextChanged="TxtBusqueda_TextChanged"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="#161920" BorderBrush="#2D323E" BorderThickness="1" CornerRadius="2">
            <DataGrid x:Name="dgEmpleados" AutoGenerateColumns="False" CanUserAddRows="False" 
                      Background="Transparent" RowHeight="34" 
                      HeadersVisibility="Column" IsReadOnly="True" 
                      GridLinesVisibility="All" HorizontalGridLinesBrush="#2D323E" VerticalGridLinesBrush="#2D323E"
                      BorderThickness="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ELEMENTO" Binding="{Binding Nombre}" Width="200">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="10,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="TURNO" Binding="{Binding TurnoTipo}" Width="70"/>
                    <DataGridTextColumn Header="SERVICIO" Binding="{Binding PuntoServicio}" Width="140"/>
                    <DataGridTextColumn Header="VIE" Binding="{Binding Viernes}" Width="55"/>
                    <DataGridTextColumn Header="SÁB" Binding="{Binding Sabado}" Width="55"/>
                    <DataGridTextColumn Header="DOM" Binding="{Binding Domingo}" Width="55"/>
                    <DataGridTextColumn Header="LUN" Binding="{Binding Lunes}" Width="55"/>
                    <DataGridTextColumn Header="MAR" Binding="{Binding Martes}" Width="55"/>
                    <DataGridTextColumn Header="MIÉ" Binding="{Binding Miercoles}" Width="55"/>
                    <DataGridTextColumn Header="JUE" Binding="{Binding Jueves}" Width="55"/>
                    <DataGridTextColumn Header="HRS" Binding="{Binding ConteoTurnos}" Width="50"/>

                    <DataGridTextColumn Header="TOTAL" Binding="{Binding TotalSueldo, StringFormat={}{0:C}}" Width="115">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="TextAlignment" Value="Right"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="0,0,8,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Grid Grid.Row="3" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#161920" BorderBrush="#2D323E" BorderThickness="1" CornerRadius="2" Margin="0,0,10,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="130"/>
                    </Grid.ColumnDefinitions>
                    <Border Background="#FFAF6E" Padding="15,5">
                        <TextBlock Text="GASTOS EXTRA" Foreground="White" FontWeight="Bold" VerticalAlignment="Center" FontSize="11" />
                    </Border>
                    <TextBox Grid.Column="1" x:Name="txtConceptoGasto" Background="#21262E" Foreground="#FFFFFF" BorderThickness="0" VerticalContentAlignment="Center" Padding="15,0" FontStyle="Italic" Text="Concepto..."/>
                    <TextBox Grid.Column="2" x:Name="txtMontoGasto" Text="0.00" Background="#161A21" Foreground="#6E6E6E" FontWeight="Bold" BorderThickness="1,0,0,0" BorderBrush="#2D323E" TextAlignment="Right" VerticalContentAlignment="Center" Padding="10,0" TextChanged="TxtMontoGasto_TextChanged"/>
                </Grid>
            </Border>

            <Border Background="#48E034" Padding="20,8" CornerRadius="2" Grid.Column="1" Margin="10,0,5,0" MinWidth="250">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="TOTAL NÓMINA" 
                   Foreground="#000000" 
                   FontWeight="Black" 
                   FontSize="13" 
                   VerticalAlignment="Center" 
                   Margin="0,0,15,0"/>

                    <Viewbox MaxHeight="40" StretchDirection="DownOnly">
                        <TextBlock x:Name="txtSubtotal" 
                       Text="$0.00" 
                       Foreground="Black" 
                       FontWeight="Black" 
                       FontSize="30" 
                       VerticalAlignment="Center"/>
                    </Viewbox>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>