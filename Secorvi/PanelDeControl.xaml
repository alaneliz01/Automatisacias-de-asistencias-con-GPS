<Page x:Class="Secorvi.PanelDeControl"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="SECORVI - Panel de Control" 
      Height="800" Width="1200"
      Background="#0B0D12" Language="es-MX">

    <Page.Resources>
        <Style x:Key="TerminalInputStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#161920"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2D323E"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CaretBrush" Value="#FFB300"/>
        </Style>

        <Style x:Key="IndustrialButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#161A21"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#2D323E"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1E2530"/>
                                <Setter Property="BorderBrush" Value="#FFB300"/>
                                <Setter Property="Cursor" Value="Hand"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#1E252F"/>
            <Setter Property="Foreground" Value="#FFB300"/>
            <Setter Property="BorderBrush" Value="#2D323E"/>
            <Setter Property="BorderThickness" Value="0,0,1,2"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#1A1F26"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#161920"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#161920" CornerRadius="8,8,0,0" Padding="20" BorderBrush="#2D323E" BorderThickness="1">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="SECORVI" Foreground="#FFB300" FontSize="26" FontWeight="Black"/>
                        <TextBlock Text="OPERATIONS CONTROL CENTER" Foreground="#4B5563" FontSize="9" FontWeight="Bold" Margin="2,-4,0,0"/>
                    </StackPanel>
                    <Rectangle Width="1" Fill="#2D323E" Margin="25,5" Height="40"/>
                    <Button Content="+ REGISTRAR AGENTE" Click="BtnNuevo_Click" Style="{StaticResource IndustrialButtonStyle}" Background="#FFB300" Foreground="#0F111A" FontWeight="Black" Width="180" Height="40"/>
                    <Button x:Name="btnRoles" Content="🛡️ PERMISOS" Click="BtnRoles_Click" Style="{StaticResource IndustrialButtonStyle}" Width="110" Height="40" Margin="10,0"/>
                    <Button Content="🧹 LIMPIAR DB" Click="BtnPurgar_Click" Style="{StaticResource IndustrialButtonStyle}" Width="120" Height="40" Margin="10,0"/>
                </StackPanel>
                <Button Content="❌ DAR DE BAJA" Click="BtnEliminar_Click" DockPanel.Dock="Right" Style="{StaticResource IndustrialButtonStyle}" Background="#3D1B1E" Foreground="#FF5252" BorderBrush="#FF5252" Width="150" Height="40"/>
            </DockPanel>
        </Border>

        <Border Grid.Row="1" Background="#12151B" Padding="20,10" BorderBrush="#2D323E" BorderThickness="1,0,1,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="FILTRAR POR ID, NOMBRE O MATRÍCULA:" Foreground="#6B7280" FontWeight="Bold" VerticalAlignment="Center" FontSize="10" Margin="0,0,15,0"/>
                <TextBox x:Name="txtBusqueda" Grid.Column="1" Height="32" Style="{StaticResource TerminalInputStyle}" TextChanged="TxtBusqueda_TextChanged"/>
                <TextBlock Grid.Column="2" x:Name="lblTotal" Text="Agentes: 0" Foreground="#4B5563" VerticalAlignment="Center" Margin="15,0,0,0" FontSize="10"/>
            </Grid>
        </Border>

        <Border Grid.Row="2" Background="#0F111A" BorderBrush="#2D323E" BorderThickness="1,0,1,1">
            <DataGrid x:Name="dgEmpleados" AutoGenerateColumns="False" CanUserAddRows="False" 
                      Background="Transparent" RowHeight="65" HeadersVisibility="Column" 
                      IsReadOnly="True" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#1A1F26"
                      BorderThickness="0" MouseDoubleClick="DgEmpleados_MouseDoubleClick">
                <DataGrid.Columns>

                    <DataGridTextColumn Header="ID BOT" Binding="{Binding id_empleado}" Width="80">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#FFB300"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="FontWeight" Value="Black"/>
                                <Setter Property="FontSize" Value="14"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="AGENTE" Binding="{Binding nombre_completo}" Width="220">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTemplateColumn Header="ASISTENCIA" Width="160">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="4" Padding="8,4" Margin="5" BorderThickness="1">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#1A1F26"/>
                                            <Setter Property="BorderBrush" Value="#2D323E"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding estatus_asistencia}" Value="PRESENTE">
                                                    <Setter Property="Background" Value="#0A2D1B"/>
                                                    <Setter Property="BorderBrush" Value="#2ECC71"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding estatus_asistencia}" Value="FALTA">
                                                    <Setter Property="Background" Value="#3D1B1E"/>
                                                    <Setter Property="BorderBrush" Value="#FF5252"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="8" Height="8" Margin="0,0,8,0">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="#4B5563"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding estatus_asistencia}" Value="PRESENTE">
                                                            <Setter Property="Fill" Value="#2ECC71"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                        <TextBlock Text="{Binding estatus_asistencia, TargetNullValue='PENDIENTE'}" 
                                                   Foreground="White" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="HORARIO ASIGNADO" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel VerticalAlignment="Center" Margin="10,0">
                                    <TextBlock Text="TURNO ACTUAL:" Foreground="#4B5563" FontSize="9" FontWeight="Black"/>
                                    <TextBlock Text="{Binding info_turno, TargetNullValue='SIN ASIGNACIÓN'}" 
                                               Foreground="#E0E0E0" FontSize="12" FontFamily="Consolas"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="ACCIONES" Width="150">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="📅 CALENDARIO" Click="BtnCalendario_Click" Style="{StaticResource IndustrialButtonStyle}" 
                                        Foreground="#FFB300" BorderBrush="#FFB300" FontSize="10" FontWeight="Bold"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Row="3" Background="#161920" CornerRadius="0,0,8,8" Padding="20,12" BorderBrush="#2D323E" BorderThickness="1,0,1,1">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Fill="#2ECC71" Margin="0,0,5,0"/>
                    <TextBlock Text="SISTEMA ONLINE" Foreground="#E0E0E0" FontSize="9" VerticalAlignment="Center"/>
                    <Rectangle Width="1" Fill="#2D323E" Margin="15,2" Height="15"/>
                    <TextBlock Text="ENGINE: n8n ACTIVE | MONITORING DATABASE" Foreground="#4B5563" FontSize="9" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock HorizontalAlignment="Right" Text="SECORVI v2.5" Foreground="#FFB300" FontSize="10" FontWeight="Black" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Page>