<Window x:Class="Secorvi.ConfirmarEliminacion"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SEGURIDAD: Confirmar Baja" 
        SizeToContent="Height" Width="450" 
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#1A1A1A" Foreground="White">
    <Border Padding="20">
        <StackPanel>
            <TextBlock Text="VALIDACIÓN DE SEGURIDAD" 
                       Foreground="#FFC107" FontWeight="Bold" 
                       FontSize="14" Margin="0,0,0,10"/>

            <TextBlock TextWrapping="Wrap" Margin="0,0,0,15" FontSize="12">
                Esta acción es irreversible. Para eliminar definitivamente al agente, 
                por favor escriba su NOMBRE COMPLETO a continuación para confirmar:
            </TextBlock>

            <TextBox Name="txtNombreConfirmar" Height="35" 
                     Background="#000000" Foreground="#FFC107" 
                     BorderBrush="#FFC107" BorderThickness="0,0,0,2"
                     VerticalContentAlignment="Center"
                     FontWeight="Bold" FontSize="14" Padding="10,0"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,25,0,0">
                <Button Name="btnEliminar" Content="CONFIRMAR ELIMINACIÓN" Click="BtnEliminar_Click" 
                        Width="180" Height="38" Background="#440000" Foreground="#FF4B4B" 
                        BorderBrush="#880000" FontWeight="Bold" Margin="0,0,10,0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="0"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button Name="btnCancelar" Content="CANCELAR" IsCancel="True"
                        Width="100" Height="38" Background="#333333" Foreground="White"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>