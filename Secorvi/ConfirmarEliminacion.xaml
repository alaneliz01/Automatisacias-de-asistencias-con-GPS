<Window x:Class="Secorvi.ConfirmarEliminacion"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Confirmar Baja" Height="250" Width="400" 
        Background="#1A1A1A" WindowStyle="None" AllowsTransparency="True">

    <Border BorderBrush="#FF4B4B" BorderThickness="1" Padding="20">
        <StackPanel>
            <TextBlock x:Name="lblInstruccion" 
                       Foreground="#888" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,5"/>

            <TextBlock x:Name="lblNombreAgente" 
                       Foreground="#FF4B4B" FontSize="18" FontWeight="Black" 
                       HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <TextBox x:Name="txtNombreConfirmar" 
                     Height="40" Background="Black" Foreground="#FFC107" 
                     BorderBrush="#FFC107" BorderThickness="0,0,0,2"
                     FontSize="14" FontWeight="Bold" Padding="5,0"
                     TextChanged="TxtNombreConfirmar_TextChanged"/>

            <Grid Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="btnEliminar" Content="CONFIRMAR" 
                        Click="BtnEliminar_Click" Margin="0,0,10,0"
                        Background="#440000" Foreground="#FF4B4B" Height="40"/>

                <Button Content="CANCELAR" Click="BtnCancelar_Click" 
                        Width="100" Background="#333" Foreground="White"/>
            </Grid>
        </StackPanel>
    </Border>
</Window>