<Page x:Class="Secorvi.GestionTurnos"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Gestión de Turnos" Background="#101217">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="AGENDAR ASIGNACIÓN" Foreground="#FFB300" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>

            <StackPanel Orientation="Horizontal">
                <StackPanel Margin="5">
                    <TextBlock Text="Agente:" Foreground="White" Margin="0,0,0,5"/>
                    <ComboBox x:Name="cbEmpleados" Width="200" DisplayMemberPath="nombre_completo"/>
                </StackPanel>

                <StackPanel Margin="5">
                    <TextBlock Text="Ubicación:" Foreground="White" Margin="0,0,0,5"/>
                    <ComboBox x:Name="cbUbicaciones" Width="200" DisplayMemberPath="nombre_lugar"/>
                </StackPanel>

                <StackPanel Margin="5">
                    <TextBlock Text="Fecha:" Foreground="White" Margin="0,0,0,5"/>
                    <DatePicker x:Name="dpFecha" Width="150"/>
                </StackPanel>

                <Button x:Name="btnGuardarTurno" Content="GUARDAR" Width="120" Height="35" Margin="10,20,0,0" 
                        Background="#FFB300" Foreground="Black" FontWeight="Bold" Click="btnGuardarTurno_Click"/>
            </StackPanel>
        </StackPanel>

        <DataGrid x:Name="dgTurnos" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" 
                  Background="#1E222D" BorderBrush="#303645" Foreground="White">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding id_asignaciones}" Width="50"/>
                <DataGridTextColumn Header="Fecha" Binding="{Binding fecha, StringFormat=d}" Width="100"/>
                <DataGridTextColumn Header="Estatus" Binding="{Binding estatus}" Width="*"/>
                <DataGridTemplateColumn Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Eliminar" Click="btnEliminarTurno_Click" Background="#CC3333" Foreground="White"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>