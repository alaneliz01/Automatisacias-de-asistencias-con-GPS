<Window x:Class="Secorvi.GestionPermisos"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gestión de Accesos" 
        SizeToContent="Height" MinHeight="450" MaxHeight="600" Width="450"
        WindowStartupLocation="CenterOwner" Background="#0B0D12"
        AllowsTransparency="True" WindowStyle="None" ResizeMode="NoResize"
        BorderBrush="#FFB300" BorderThickness="1">

    <Window.Resources>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#161920"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="gd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="gd" Property="Background" Value="#FFB300"/>
                                <Setter Property="Foreground" Value="#0F111A"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="gd" Property="Background" Value="#2D323E"/>
                                <Setter Property="Foreground" Value="#FFB300"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IndustrialComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#161920"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2D323E"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" 
                                        BorderBrush="{TemplateBinding BorderBrush}" 
                                        Background="{TemplateBinding Background}" 
                                        Grid.Column="2" Focusable="false"
                                        IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                        ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Border" CornerRadius="2" Background="#161920" BorderBrush="#2D323E" BorderThickness="1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition />
                                                    <ColumnDefinition Width="30" />
                                                </Grid.ColumnDefinitions>
                                                <Path Grid.Column="1" Fill="#FFB300" HorizontalAlignment="Center" VerticalAlignment="Center" Data="M 0 0 L 4 4 L 8 0 Z" />
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter Name="ContentSite" IsHitTestVisible="False" 
                                            Content="{TemplateBinding SelectionBoxItem}"
                                            ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                            Margin="10,3,30,3" VerticalAlignment="Center" HorizontalAlignment="Left" />
                            <Popup Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid Name="DropDown" SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="150">
                                    <Border x:Name="DropDownBorder" Background="#161920" BorderThickness="1" BorderBrush="#2D323E"/>
                                    <ScrollViewer Margin="4,6,4,6" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="25">
            <StackPanel>
                <TextBlock Text="MODIFICAR NIVEL DE ACCESO" Foreground="#FFB300" FontSize="18" FontWeight="Black" Margin="0,0,0,5"/>
                <TextBlock Text="CONFIGURACIÓN DE SEGURIDAD INTERNA" Foreground="#4B5563" FontSize="9" FontWeight="Bold" Margin="0,0,0,15"/>

                <Separator Background="#2D323E" Margin="0,0,0,20"/>

                <TextBlock Text="AGENTE SELECCIONADO:" Foreground="#6B7280" FontSize="10" FontWeight="Bold"/>
                <TextBlock x:Name="lblNombreEmpleado" Text="CARGANDO..." Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,5,0,20"/>

                <TextBlock Text="ASIGNAR NUEVO ROL:" Foreground="#6B7280" FontSize="10" FontWeight="Bold" Margin="0,0,0,5"/>
                <ComboBox x:Name="cbRoles" Style="{StaticResource IndustrialComboBox}" Height="45" 
                          SelectionChanged="CbRoles_SelectionChanged"/>

                <Border Background="#0F111A" CornerRadius="4" Padding="15" Margin="0,20,0,25" BorderBrush="#2D323E" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="ALCANCE DEL ROL:" Foreground="#FFB300" FontSize="9" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBlock x:Name="txtDescripcionRol" Text="Seleccione un rol para ver los detalles..." 
                                   Foreground="#9CA3AF" FontSize="12" TextWrapping="Wrap" LineHeight="18"/>
                    </StackPanel>
                </Border>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Content="CANCELAR" Click="BtnCancelar_Click" Margin="0,0,5,0" Height="40" 
                            Background="#1A1F26" Foreground="#9CA3AF" BorderBrush="#2D323E"/>
                    <Button Content="APLICAR CAMBIOS" x:Name="btnGuardar" Click="BtnGuardar_Click" 
                            Grid.Column="1" Margin="5,0,0,0" Height="40" 
                            Background="#FFB300" Foreground="#0B0D12" FontWeight="Black"/>
                </Grid>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Window>