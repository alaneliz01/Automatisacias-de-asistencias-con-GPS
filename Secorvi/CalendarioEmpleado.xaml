<Page x:Class="Secorvi.CalendarioEmpleado"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Secorvi"
      mc:Ignorable="d" 
      Background="#0B0D12" Language="es-MX"
      d:DesignHeight="750" d:DesignWidth="1100"
      Title="Calendario de Agente">

    <Page.Resources>
        <SolidColorBrush x:Key="PrimaryYellow" Color="#FFB300"/>
        <SolidColorBrush x:Key="DeepPanel" Color="#161920"/>
        <SolidColorBrush x:Key="BorderGray" Color="#2D323E"/>
        <SolidColorBrush x:Key="TextMuted" Color="#6B7280"/>
        <SolidColorBrush x:Key="AccentBlue" Color="#3498DB"/>

        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background" Value="#161920"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="BorderBrush" Value="#2D323E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="HeaderButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1A1F26"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#2D323E"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2C3E50"/>
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryYellow}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BackButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1A1F26"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryYellow}"/>
            <Setter Property="BorderBrush" Value="#2D323E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="Margin" Value="0,0,15,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimaryYellow}"/>
                    <Setter Property="Foreground" Value="Black"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.ColumnSpan="2" Style="{StaticResource StatCard}" Padding="12" Margin="0,0,0,15">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                    <Button Content="◀ VOLVER" Click="BtnVolver_Click" Style="{StaticResource BackButtonStyle}" FontWeight="Bold" FontSize="10"/>
                    <Rectangle Width="1" Height="25" Fill="{StaticResource BorderGray}" Margin="5,0,15,0"/>
                    <TextBlock x:Name="lblNombreEmpleado" Foreground="{StaticResource PrimaryYellow}" FontSize="24" FontWeight="Bold" VerticalAlignment="Center" Text="CARGANDO AGENTE..."/>
                    <TextBlock x:Name="lblFechaHoraActual" Margin="15,0,0,0" Foreground="White" FontSize="14" VerticalAlignment="Center" Opacity="0.4" Text="| 16 DE ABRIL | 2026"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="◀" Width="40" Height="32" Style="{StaticResource HeaderButtonStyle}" Click="BtnSemanaAtras_Click" Margin="0,0,5,0"/>
                    <DatePicker x:Name="dpSaltoFecha" Width="130" Height="32" VerticalAlignment="Center" SelectedDateChanged="DpSaltoFecha_SelectedDateChanged" />
                    <Button Content="▶" Width="40" Height="32" Style="{StaticResource HeaderButtonStyle}" Click="BtnSemanaAdelante_Click" Margin="5,0,15,0"/>

                    <Button Content="📍 ASIGNAR SERVICIO" Click="BtnAsignarHorario_Click" Background="{StaticResource PrimaryYellow}" Foreground="Black" FontWeight="Bold" Padding="20,8" BorderThickness="0" Cursor="Hand" />
                </StackPanel>
            </DockPanel>
        </Border>

        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,15,0">
            <TextBlock Text="MÉTRICAS SEMANALES" Foreground="{StaticResource TextMuted}" FontSize="10" FontWeight="Bold" Margin="5,0,0,8" />
            <Border Style="{StaticResource StatCard}">
                <StackPanel>
                    <TextBlock Text="SERVICIOS ACTIVOS" Foreground="{StaticResource TextMuted}" FontSize="10" FontWeight="Bold"/>
                    <TextBlock x:Name="lblTotalServicios" Text="0" Foreground="#C0392B" FontSize="32" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCard}">
                <StackPanel>
                    <TextBlock Text="DÍAS DE DESCANSO" Foreground="{StaticResource TextMuted}" FontSize="10" FontWeight="Bold"/>
                    <TextBlock x:Name="lblTotalDescansos" Text="0" Foreground="#95A5A6" FontSize="32" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCard}">
                <StackPanel>
                    <TextBlock Text="VACACIONES" Foreground="{StaticResource TextMuted}" FontSize="10" FontWeight="Bold"/>
                    <TextBlock x:Name="lblTotalVacaciones" Text="0" Foreground="{StaticResource AccentBlue}" FontSize="32" FontWeight="Bold"/>
                </StackPanel>
            </Border>


            <TextBlock Text="GUÍA TÁCTICA" Foreground="{StaticResource TextMuted}" FontSize="10" FontWeight="Bold" Margin="5,15,0,8" />
            <Border Background="#0F111A" CornerRadius="8" Padding="15" BorderBrush="{StaticResource BorderGray}" BorderThickness="1">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                        <Ellipse Width="8" Height="8" Fill="#3498DB" Margin="0,0,10,0"/>
                        <TextBlock Text="AZUL: Vacaciones" Foreground="White" FontSize="10"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                        <Ellipse Width="8" Height="8" Fill="#374151" Margin="0,0,10,0"/>
                        <TextBlock Text="GRIS: Descanso" Foreground="White" FontSize="10"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Ellipse Width="8" Height="8" Fill="#C0392B" Margin="0,0,10,0"/>
                        <TextBlock Text="ROJO: Servicio Activo" Foreground="White" FontSize="10"/>
                    </StackPanel>

                    <Rectangle Height="1" Fill="{StaticResource BorderGray}" Margin="0,0,0,12"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="🖱️" Margin="0,0,8,0" FontSize="10"/>
                        <TextBlock Text="ARRASTRAR: Seleccionar rango" Foreground="#6B7280" FontSize="10"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="🔘" Margin="0,0,8,0" FontSize="10"/>
                        <TextBlock Text="CLIC DER: Menú de gestión" Foreground="#6B7280" FontSize="10"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📍" Margin="0,0,8,0" FontSize="10"/>
                        <TextBlock Text="BOTÓN: Asignar a punto GPS" Foreground="#6B7280" FontSize="10"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>

        <Grid Grid.Row="1" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Background="#1E252F" CornerRadius="6" Padding="12" Margin="0,0,0,12" BorderBrush="{StaticResource BorderGray}" BorderThickness="1">
                <TextBlock x:Name="lblRangoSemana" Foreground="{StaticResource AccentBlue}" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Text="LUNES 13 - DOMINGO 19 DE ABRIL"/>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Background="#0F111A">
                <Grid x:Name="GridCalendario" ShowGridLines="False">
                    <Grid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Limpiar Día" Click="MenuItem_LimpiarDia_Click"/>
                            <MenuItem Header="Copiar a siguiente día" Click="MenuItem_CopiarDia_Click"/>
                        </ContextMenu>
                    </Grid.ContextMenu>
                </Grid>
            </ScrollViewer>
        </Grid>

        <Border Grid.Row="2" Grid.ColumnSpan="2" Background="#161920" CornerRadius="8" Padding="12" Margin="0,15,0,0" BorderBrush="{StaticResource BorderGray}" BorderThickness="1">
            <DockPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Fill="#2ECC71" Margin="0,0,10,0"/>
                    <TextBlock x:Name="lblStatus" Text="COMMAND CENTER ONLINE" Foreground="#2ECC71" FontSize="10" FontWeight="Bold"/>
                </StackPanel>
                <TextBlock Text="SECORVI MONITORING SYSTEM v2.0" Foreground="{StaticResource TextMuted}" FontSize="9" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>
    </Grid>
</Page>