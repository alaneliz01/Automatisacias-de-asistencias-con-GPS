<Window x:Class="Secorvi.RegistroEmpleado"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SECORVI - Registro" Height="650" Width="380"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="TerminalInputStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#1F2937"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#374151"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CaretBrush" Value="#FFB300"/>
        </Style>

        <Style x:Key="GoldButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FFB300"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="Black"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E6A100"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Background="#111827" CornerRadius="15" BorderBrush="#374151" BorderThickness="1.5">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#1F2937" CornerRadius="15,15,0,0" 
                    MouseLeftButtonDown="Border_MouseLeftButtonDown">
                <DockPanel Margin="20,0">
                    <TextBlock Text="🛡️ ALTA DE AGENTE" Foreground="#FFB300" FontWeight="Bold" VerticalAlignment="Center"/>
                    <Button Content="✕" Click="BtnCancelar_Click" HorizontalAlignment="Right" 
                            Background="Transparent" Foreground="White" BorderThickness="0" FontWeight="Bold" Cursor="Hand"/>
                </DockPanel>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
                <StackPanel Margin="30,20">

                    <TextBlock Text="MATRÍCULA (CONTROL INTERNO)" Foreground="#6B7280" FontSize="10" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtMatricula" IsReadOnly="True" Style="{StaticResource TerminalInputStyle}" 
                             Foreground="#9CA3AF" Background="#0F172A" Margin="0,0,0,15"/>

                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,15,0">
                            <TextBlock Text="ID WHATSAPP" Foreground="#FFB300" FontSize="10" FontWeight="Bold" Margin="0,0,0,5"/>
                            <Border Background="#1F2937" BorderBrush="#FFB300" BorderThickness="1.5" Padding="15,8" CornerRadius="5">
                                <TextBlock x:Name="lblIdGenerado" Text="--" Foreground="#FFB300" FontWeight="Black" FontSize="18" HorizontalAlignment="Center"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="1" VerticalAlignment="Bottom" Margin="0,0,0,2">
                            <TextBlock Text="IDENTIFICADOR DE BOT" Foreground="#6B7280" FontSize="10" FontWeight="Bold" Margin="0,0,0,3"/>
                            <TextBlock Text="ID ÚNICO DE AGENTE" Foreground="#9CA3AF" FontSize="12" FontWeight="SemiBold"/>

                            <TextBlock x:Name="lblIdRol" Text="3" Visibility="Collapsed"/>
                        </StackPanel>
                    </Grid>

                    <Separator Background="#1F2937" Margin="0,0,0,20"/>

                    <TextBlock Text="NOMBRE(S)" Foreground="#6B7280" FontSize="10" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtNombre" Style="{StaticResource TerminalInputStyle}" Margin="0,0,0,15"/>

                    <TextBlock Text="APELLIDOS" Foreground="#6B7280" FontSize="10" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtApellido" Style="{StaticResource TerminalInputStyle}" Margin="0,0,0,15"/>

                    <TextBlock Text="WHATSAPP (10 DÍGITOS)" Foreground="#6B7280" FontSize="10" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtTelefono" Style="{StaticResource TerminalInputStyle}" Margin="0,0,0,15" MaxLength="10"/>

                    <TextBlock Text="CONTRASEÑA" Foreground="#6B7280" FontSize="10" FontWeight="Bold" Margin="0,0,0,5"/>
                    <PasswordBox x:Name="txtPass" Background="#1F2937" Foreground="White" BorderBrush="#374151" 
                                 Padding="10" Margin="0,0,0,25"/>

                    <Button Content="REGISTRAR EN SECORVI" Click="BtnGuardar_Click" 
                            Height="45" Style="{StaticResource GoldButtonStyle}"/>

                    <Button Content="CANCELAR OPERACIÓN" Click="BtnCancelar_Click" Margin="0,15,0,0" 
                            Background="Transparent" Foreground="#4B5563" BorderThickness="0" Cursor="Hand" FontSize="10"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>