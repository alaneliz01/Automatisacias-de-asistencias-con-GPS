<Window x:Class="Secorvi.RegistroEmpleado"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SECORVI - Nuevo Agente" Height="500" Width="350" 
        Background="#161618" WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True">

    <Border BorderBrush="#2D323E" BorderThickness="1" CornerRadius="10">
        <StackPanel Margin="30">
            <TextBlock Text="REGISTRO TÁCTICO" Foreground="#FFC107" FontWeight="Bold" FontSize="16" Margin="0,0,0,20" HorizontalAlignment="Center"/>

            <TextBlock Text="MATRÍCULA (AUTO)" Foreground="#555" FontSize="10" FontWeight="Bold"/>
            <TextBox x:Name="txtMatricula" IsReadOnly="True" Background="#252526" Foreground="#888" Padding="10" Margin="0,5,0,15" BorderThickness="0"/>

            <TextBlock Text="NOMBRE COMPLETO" Foreground="#555" FontSize="10" FontWeight="Bold"/>
            <TextBox x:Name="txtNombre" Background="#252526" Foreground="White" Padding="10" Margin="0,5,0,15" BorderThickness="0"/>

            <TextBlock Text="WHATSAPP (10 DÍGITOS)" Foreground="#555" FontSize="10" FontWeight="Bold"/>
            <TextBox x:Name="txtTelefono" Background="#252526" Foreground="White" Padding="10" Margin="0,5,0,15" BorderThickness="0"/>

            <TextBlock Text="CONTRASEÑA DE ACCESO" Foreground="#555" FontSize="10" FontWeight="Bold"/>
            <PasswordBox x:Name="txtPass" Background="#252526" Foreground="White" Padding="10" Margin="0,5,0,25" BorderThickness="0"/>

            <Button Content="GUARDAR AGENTE" Click="BtnGuardar_Click" Height="45" Background="#FFC107" Foreground="Black" FontWeight="Bold" Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                </Button.Resources>
            </Button>

            <Button Content="CANCELAR" Click="BtnCancelar_Click" Margin="0,10,0,0" Background="Transparent" Foreground="#666" BorderThickness="0" Cursor="Hand"/>
        </StackPanel>
    </Border>
</Window>